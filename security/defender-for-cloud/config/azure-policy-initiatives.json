{
  "name": "DefenderForCloudGovernmentBaseline",
  "properties": {
    "displayName": "Microsoft Defender for Cloud - Government Baseline",
    "description": "Comprehensive policy initiative for government agencies implementing Microsoft Defender for Cloud with FedRAMP High, StateRAMP, and CJIS compliance requirements.",
    "metadata": {
      "category": "Security Center",
      "version": "1.0.0",
      "compliance": [
        "FedRAMP High",
        "StateRAMP",
        "NIST SP 800-53 Rev. 5",
        "NIST SP 800-171",
        "CJIS Security Policy"
      ]
    },
    "policyType": "Custom",
    "policyDefinitions": [
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/ac4a19c2-fa67-49b4-8ae5-0b2e78c49457",
        "policyDefinitionReferenceId": "EnableDefenderForServers",
        "groupNames": ["WorkloadProtection"],
        "parameters": {
          "effect": {
            "value": "DeployIfNotExists"
          },
          "pricingTier": {
            "value": "Standard"
          },
          "subPlan": {
            "value": "P2"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/b40e7bcd-a1e5-47fe-b9cf-2f534d0bfb7d",
        "policyDefinitionReferenceId": "EnableDefenderForSQL",
        "groupNames": ["WorkloadProtection"],
        "parameters": {
          "effect": {
            "value": "DeployIfNotExists"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/74c30959-af11-47b3-9ed2-a26e03f427a3",
        "policyDefinitionReferenceId": "EnableDefenderForStorage", 
        "groupNames": ["WorkloadProtection"],
        "parameters": {
          "effect": {
            "value": "DeployIfNotExists"
          },
          "isEnabled": {
            "value": true
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/708b60a6-d253-4fe0-9114-4be4c00f012c",
        "policyDefinitionReferenceId": "EnableDefenderForContainers",
        "groupNames": ["WorkloadProtection"],
        "parameters": {
          "effect": {
            "value": "DeployIfNotExists"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/47a6b606-51aa-4496-8bb7-64b11cf66adc",
        "policyDefinitionReferenceId": "DeployAzureMonitorAgent",
        "groupNames": ["Monitoring"],
        "parameters": {
          "effect": {
            "value": "DeployIfNotExists"
          },
          "listOfImageIdToInclude": {
            "value": []
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/845857af-0333-4c5d-bbbc-6076697da122",
        "policyDefinitionReferenceId": "ConfigureLogAnalyticsWorkspace",
        "groupNames": ["Monitoring"],
        "parameters": {
          "logAnalytics": {
            "value": "[parameters('logAnalyticsWorkspaceId')]"
          },
          "effect": {
            "value": "DeployIfNotExists"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/a4af4a39-4135-47fb-b175-47fbdf85311d",
        "policyDefinitionReferenceId": "RequireEncryptionInTransit",
        "groupNames": ["DataProtection"],
        "parameters": {
          "effect": {
            "value": "Audit"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/22bee202-a82f-4305-9a2a-6d7f44d4dedb",
        "policyDefinitionReferenceId": "RequireEncryptionAtRest",
        "groupNames": ["DataProtection"],
        "parameters": {
          "effect": {
            "value": "AuditIfNotExists"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/1f68a601-6e6d-4e42-babf-3f643a047ea2",
        "policyDefinitionReferenceId": "RequireMFAForAdministrators",
        "groupNames": ["IdentityAndAccess"],
        "parameters": {
          "effect": {
            "value": "AuditIfNotExists"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/9297c21d-2ed6-4474-b48f-163f75654ce3",
        "policyDefinitionReferenceId": "RequireNetworkSecurityGroups",
        "groupNames": ["NetworkSecurity"],
        "parameters": {
          "effect": {
            "value": "AuditIfNotExists"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/564feb30-bf6a-4854-b4bb-0d2d2d1e6c66",
        "policyDefinitionReferenceId": "DisablePublicNetworkAccess",
        "groupNames": ["NetworkSecurity"],
        "parameters": {
          "effect": {
            "value": "Audit"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/1a4e592a-6a6e-44a5-9814-e36264ca96e7",
        "policyDefinitionReferenceId": "RequirePrivateEndpoints",
        "groupNames": ["NetworkSecurity"], 
        "parameters": {
          "effect": {
            "value": "AuditIfNotExists"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/013e242c-8828-4970-87b3-ab247555486d",
        "policyDefinitionReferenceId": "EnableVulnerabilityAssessment",
        "groupNames": ["VulnerabilityManagement"],
        "parameters": {
          "effect": {
            "value": "AuditIfNotExists"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/89099bee-89e0-4b26-a5f4-165451757743",
        "policyDefinitionReferenceId": "ConfigureSecurityContacts",
        "groupNames": ["IncidentResponse"],
        "parameters": {
          "effect": {
            "value": "DeployIfNotExists"
          },
          "emailSecurityContact": {
            "value": "[parameters('securityContactEmail')]"
          },
          "phoneSecurityContact": {
            "value": "[parameters('securityContactPhone')]"
          }
        }
      },
      {
        "policyDefinitionId": "/providers/Microsoft.Authorization/policyDefinitions/74c3584d-afae-46f7-a20a-6f8adba71a16",
        "policyDefinitionReferenceId": "ConfigureAutoProvisioning",
        "groupNames": ["AutoProvisioning"],
        "parameters": {
          "effect": {
            "value": "DeployIfNotExists"
          }
        }
      }
    ],
    "policyDefinitionGroups": [
      {
        "name": "WorkloadProtection",
        "displayName": "Workload Protection Plans",
        "description": "Policies for enabling Microsoft Defender workload protection plans"
      },
      {
        "name": "Monitoring",
        "displayName": "Security Monitoring",
        "description": "Policies for configuring security monitoring and logging"
      },
      {
        "name": "DataProtection", 
        "displayName": "Data Protection",
        "description": "Policies for ensuring data encryption and protection"
      },
      {
        "name": "IdentityAndAccess",
        "displayName": "Identity and Access Management",
        "description": "Policies for securing identity and access controls"
      },
      {
        "name": "NetworkSecurity",
        "displayName": "Network Security",
        "description": "Policies for network segmentation and protection"
      },
      {
        "name": "VulnerabilityManagement",
        "displayName": "Vulnerability Management", 
        "description": "Policies for vulnerability assessment and management"
      },
      {
        "name": "IncidentResponse",
        "displayName": "Incident Response",
        "description": "Policies for incident response configuration"
      },
      {
        "name": "AutoProvisioning",
        "displayName": "Auto-Provisioning",
        "description": "Policies for automatic agent and extension provisioning"
      }
    ],
    "parameters": {
      "logAnalyticsWorkspaceId": {
        "type": "String",
        "metadata": {
          "displayName": "Log Analytics Workspace ID",
          "description": "The resource ID of the Log Analytics workspace for security data collection",
          "strongType": "Microsoft.OperationalInsights/workspaces"
        }
      },
      "securityContactEmail": {
        "type": "String",
        "metadata": {
          "displayName": "Security Contact Email",
          "description": "Email address for security notifications and alerts"
        }
      },
      "securityContactPhone": {
        "type": "String",
        "metadata": {
          "displayName": "Security Contact Phone",
          "description": "Phone number for critical security notifications"
        },
        "defaultValue": ""
      }
    }
  },
  "compliance": {
    "fedrampHigh": {
      "controlMappings": {
        "AC-2": ["RequireMFAForAdministrators", "ConfigureAutoProvisioning"],
        "AC-3": ["RequireNetworkSecurityGroups", "RequirePrivateEndpoints"],
        "AU-3": ["DeployAzureMonitorAgent", "ConfigureLogAnalyticsWorkspace"],
        "AU-6": ["ConfigureSecurityContacts"],
        "CA-7": ["EnableDefenderForServers", "EnableDefenderForSQL"],
        "CM-7": ["DisablePublicNetworkAccess"],
        "IA-2": ["RequireMFAForAdministrators"],
        "IR-4": ["ConfigureSecurityContacts"],
        "RA-5": ["EnableVulnerabilityAssessment"],
        "SC-7": ["RequireNetworkSecurityGroups", "RequirePrivateEndpoints"],
        "SC-8": ["RequireEncryptionInTransit"],
        "SC-13": ["RequireEncryptionAtRest"],
        "SC-28": ["RequireEncryptionAtRest"],
        "SI-2": ["EnableVulnerabilityAssessment"],
        "SI-4": ["EnableDefenderForServers", "EnableDefenderForContainers"]
      }
    },
    "nist80053": {
      "controlFamilies": [
        "AC - Access Control",
        "AU - Audit and Accountability", 
        "CA - Assessment, Authorization, and Monitoring",
        "CM - Configuration Management",
        "IA - Identification and Authentication",
        "IR - Incident Response",
        "RA - Risk Assessment",
        "SC - System and Communications Protection",
        "SI - System and Information Integrity"
      ]
    },
    "nist800171": {
      "requirements": [
        "3.1.1 - Limit system access to authorized users",
        "3.1.2 - Limit system access to the types of transactions",
        "3.3.1 - Create and retain system audit logs",
        "3.3.8 - Protect audit information and audit logging tools",
        "3.4.1 - Establish and maintain baseline configurations",
        "3.5.1 - Identify system users, processes acting on behalf of users",
        "3.5.2 - Authenticate identities of users, processes, or devices",
        "3.6.1 - Establish an operational incident-handling capability",
        "3.11.1 - Periodically assess the security controls",
        "3.13.1 - Monitor, control, and protect communications",
        "3.13.11 - Employ cryptographic mechanisms",
        "3.13.16 - Protect the confidentiality of CUI",
        "3.14.1 - Identify, report, and correct information system flaws"
      ]
    },
    "cjis": {
      "sections": [
        "5.4.1.3 - Multi-Factor Authentication (AAL2)",
        "5.8.2 - Audit Log Retention (7 years)",
        "5.10.1.2 - Encryption in Transit (TLS 1.2+)",
        "5.10.1.3 - Encryption at Rest (FIPS 140-2 Level 1+)",
        "5.12.1 - Cloud Service Provider Security"
      ]
    }
  }
}